# 환경변수 예시(.env)
# 실제 프로젝트에서는 비밀키를 소스에 커밋하지 마세요.

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=REPLACE_ME
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE_ME
GOOGLE_OAUTH_REDIRECT_URI=com.example.app:/oauth2redirect

# data.go.kr
DATA_GO_KR_SERVICE_KEY=REPLACE_ME

# ALIO
ALIO_API_KEY=REPLACE_ME

# Worknet
WORKNET_API_KEY=REPLACE_ME

# YouTube Data API (옵션)
YOUTUBE_DATA_API_KEY=REPLACE_ME
